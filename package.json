{
  "name": "whisker",
  "displayName": "Whisker Article Checker",
  "description": "A VS Code extension for our content writers that validates and shows approved tags for ConfigCat blog articles.",
  "version": "1.0.2",
  "publisher": "configcat",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other", "Linters"],
  "activationEvents": [
    "onLanguage:markdown"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "whisker.validate",
        "title": "Whisker: Validate Article"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./tsconfig.json",
    "watch": "tsc -watch -p ./tsconfig.json",
    "package": "npm install -g @vscode/vsce && vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^18.0.0",
    "typescript": "^5.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/configcat-labs/Whisker"
  },
  "license": "MIT"
}
